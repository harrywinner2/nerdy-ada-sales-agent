# ===== Deployed-app runtime secrets (NOT used during build) =====
# OpenAI — powers Realtime voice (STT+TTS+reasoning), embeddings, judging
OPENAI_API_KEY=sk-...

# Twilio — powers the live PHONE channel (Media Streams -> our WS relay)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...          # the number prospects call / we dial from

# App config (safe defaults; override in deploy if needed)
PUBLIC_BASE_URL=                   # set to the Railway https URL after deploy (for Twilio webhooks)
OPENAI_REALTIME_MODEL=gpt-realtime
